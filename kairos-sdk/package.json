{
  "name": "kairos-sdk",
  "version": "0.1.0",
  "description": "Kairos SDK — instrument autonomous systems in 3 lines",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "kairos",
    "ai",
    "agents",
    "tracing",
    "observability",
    "replay",
    "autonomous"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
