{
  "name": "kairos",
  "private": true,
  "version": "0.1.0",
  "description": "The control layer for autonomous operations.",
  "workspaces": [
    "kairos-web",
    "kairos-sdk",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter kairos-web dev",
    "dev:api": "cd kairos-core && uvicorn app.main:app --reload",
    "build:web": "pnpm --filter kairos-web build",
    "build:sdk": "pnpm --filter @kairos/sdk build"
  },
  "packageManager": "pnpm@9.0.0"
}
